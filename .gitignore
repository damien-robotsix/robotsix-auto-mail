.venv/
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Environment files (may contain credentials)
.env
.env.*
!.env.example

# Real mail configuration (may contain credentials)
config/mail.local.yaml

# Runtime SQLite store written by the ingest pipeline. Local runs use
# ./.data/mail.db; the Docker stack bind-mounts ./.mail_data for it. The
# .mail_data dir is tracked (via .gitkeep) so Docker doesn't create it as
# root — only its contents are ignored.
/.data/
/.mail_data/*
!/.mail_data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm
