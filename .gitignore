.venv/
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/

# MkDocs build output (never committed; built by the docs workflow).
site/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage

# Ephemeral lockfile export produced by CI for pip-audit (never committed;
# uv.lock is the source of truth).
requirements-locked.txt

# uv tool binaries & archives (downloaded by CI-fix sandbox; never commit)
uv-x86_64-unknown-linux-gnu/
uv.tgz

# Environment files (may contain credentials)
.env
.env.*
!.env.example

# Real mail configuration (may contain credentials)
config/mail.local.yaml

# Runtime SQLite store written by the ingest pipeline. Local runs use
# ./.data/mail.db; the Docker stack bind-mounts ./.mail_data for it. The
# .mail_data dir is tracked (via .gitkeep) so Docker doesn't create it as
# root — only its contents are ignored.
/.data/
/.mail_data/*
!/.mail_data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm

# Runtime log directory — bind-mounted and persisted on the host.
/.mail_log/*
!/.mail_log/.gitkeep
