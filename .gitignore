.venv/
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Environment files (may contain credentials)
.env
.env.*
!.env.example

# Real mail configuration (may contain credentials)
config/mail.toml
config/mail.local.yaml

# Runtime SQLite store written by the ingest pipeline. The production
# default is /home/mailbot/data/mail.db (inside the Docker image), but
# local CLI runs may resolve it to ./mail.db at the repo root.
/mail.db
*.db
*.db-journal
*.db-wal
*.db-shm
