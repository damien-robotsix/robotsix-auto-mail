# -------------------------------------------------------------------------
# deploy/.env — environment for the server.robotsix.net stack.
# Copy to deploy/.env and edit. docker compose auto-loads it.
#   cp .env.example .env && $EDITOR .env
# -------------------------------------------------------------------------

# Published image tag Watchtower tracks. `main` is the moving tag pushed on
# every merge to main; pin a version (e.g. v1.2.3) to freeze deploys.
IMAGE_TAG=main

# Host loopback port the board is published on (proxied by nginx).
# The container always serves on 8080; this only sets the host side.
BOARD_PORT=8080

# OpenRouter / LLM key used by detect, triage, and config-sync. Leave blank
# if you configure llm.api_key in config/mail.local.yaml instead.
LLM_API_KEY=
