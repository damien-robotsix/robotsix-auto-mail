# Example environment-variable configuration for robotsix-auto-mail.
#
# Copy this file to .env and fill in your real values (for direnv, IDE
# auto-detection, CI pipelines, or manual sourcing).
# .env is git-ignored so credentials never land in the repo.
#
# See also config/mail.example.toml for the TOML equivalent.

# Hostname of the IMAP server (required).
MAIL_IMAP_HOST=imap.example.com

# Port number (default: 993).
# MAIL_IMAP_PORT=993

# TLS negotiation mode – one of "starttls", "direct-tls", "none".
# "direct-tls": TLS from the first byte (typically port 993).
# "starttls":   plain connection upgraded via STARTTLS (typically port 143).
# "none":       no TLS at all (INSECURE – local dev only!).
# MAIL_IMAP_TLS_MODE=direct-tls

# IMAP folder (mailbox) to watch for new mail (default: "INBOX").
# MAIL_IMAP_FOLDER=INBOX

# Hostname of the SMTP server (required).
MAIL_SMTP_HOST=smtp.example.com

# Port number (default: 587).
# MAIL_SMTP_PORT=587

# TLS negotiation mode – one of "starttls", "direct-tls", "none".
# "starttls":   plain connection upgraded via STARTTLS (typically port 587).
# "direct-tls": TLS from the first byte (typically port 465).
# "none":       no TLS at all (INSECURE – local dev only!).
# MAIL_SMTP_TLS_MODE=starttls

# Login username (typically the full email address).
MAIL_USERNAME=user@example.com

# Login password (plaintext – will be masked in logs / repr).
MAIL_PASSWORD=s3cret

# Path to the local SQLite database file (default: "mail.db").
# MAIL_DB_PATH=mail.db
