# Example environment variables for robotsix-auto-mail.
#
# This file is a **documentation artifact** — it lists every MAIL_*
# variable the CLI accepts.  The application does NOT parse .env files
# at runtime (no python-dotenv).  Set these in your shell, docker-compose
# env block, CI, or IDE before invoking the CLI.
#
# Format is compatible with:
#   - direnv (via `dotenv` in .envrc)
#   - IDE auto-detection (VSCode, PyCharm)
#   - Manual shell sourcing:  set -a && source .env.example && set +a
#   - CI env: blocks (GitHub Actions, etc.)
#
# See also config/mail.local.example.yaml for the file-based equivalent.

# ---------------------------------------------------------------------------
# IMAP (incoming mail)
# ---------------------------------------------------------------------------

# Hostname of the IMAP server (required).
MAIL_IMAP_HOST=imap.example.com

# IMAP port (default: 993).
MAIL_IMAP_PORT=993

# TLS negotiation mode — one of "starttls", "direct-tls", "none" (default: direct-tls).
MAIL_IMAP_TLS_MODE=direct-tls

# IMAP folder (mailbox) to watch for new mail (default: INBOX).
MAIL_IMAP_FOLDER=INBOX

# ---------------------------------------------------------------------------
# SMTP (outgoing mail)
# ---------------------------------------------------------------------------

# Hostname of the SMTP server (required).
MAIL_SMTP_HOST=smtp.example.com

# SMTP port (default: 587).
MAIL_SMTP_PORT=587

# TLS negotiation mode — one of "starttls", "direct-tls", "none" (default: starttls).
MAIL_SMTP_TLS_MODE=starttls

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Login username — typically the full email address (required).
MAIL_USERNAME=user@example.com

# Login password — will be masked in logs/repr (required).
MAIL_PASSWORD=your-password-here

# OAuth2 access token for SASL XOAUTH2 (optional — overrides MAIL_PASSWORD when set).
# When MAIL_OAUTH2_TOKEN is set, password-based login() is not used.
MAIL_OAUTH2_TOKEN=

# OAuth2 client ID — required by some providers alongside the token (optional).
MAIL_OAUTH2_CLIENT_ID=

# OAuth2 client secret — required by some providers alongside the token (optional).
MAIL_OAUTH2_CLIENT_SECRET=

# MSAL OAuth2 provider — set to "microsoft" to acquire/refresh tokens via MSAL
# instead of password auth (optional; default empty = disabled).
MAIL_OAUTH2_PROVIDER=

# Azure AD tenant for MSAL-managed OAuth2 (default: organizations).
MAIL_OAUTH2_TENANT=organizations

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Path to the SQLite database file (default: .data/mail.db).
MAIL_DB_PATH=.data/mail.db

# ---------------------------------------------------------------------------
# Automatic ingestion (used by `ingest --watch`)
# ---------------------------------------------------------------------------

# Minutes between automatic ingest cycles (default: 15).
MAIL_INGEST_INTERVAL=15

# ---------------------------------------------------------------------------
# Archive (self-managed folder structure)
# ---------------------------------------------------------------------------

# Root folder under which the managed archive structure lives
# (default: robotsix-mail-archive).
MAIL_ARCHIVE_ROOT=robotsix-mail-archive

# Whether to create/manage the archive folder structure (default: true).
MAIL_ARCHIVE_ENABLED=true

# ---------------------------------------------------------------------------
# Inbox triage
# ---------------------------------------------------------------------------

# Whether to run the inbox triage agent automatically after each ingest
# (default: true).
MAIL_TRIAGE_ON_INGEST=true

# ---------------------------------------------------------------------------
# Calendar (Add to Calendar — agent-comm dispatch)
# ---------------------------------------------------------------------------

# Whether the 'Add to Calendar' button appears in the mail detail view
# and dispatches calendar event requests to the robotsix-calendar agent
# (default: true).
MAIL_CALENDAR_ENABLED=true

# ---------------------------------------------------------------------------
# Component agent (HTTP API for external agents)
# ---------------------------------------------------------------------------

# Whether the component-agent HTTP API (monitor, config-get, config-set)
# is served on the board server (default: false).
COMPONENT_AGENT_ENABLED=false

# Transport mode for calendar dispatch — "in-process" (default) uses a local
# Registry; "brokered" connects to the secured broker server over TLS with
# token auth.
CALENDAR_TRANSPORT=in-process

# Broker server hostname (required when CALENDAR_TRANSPORT=brokered).
CALENDAR_BROKER_HOST=

# Broker server port (default: 443 — the broker's public TLS endpoint).
CALENDAR_BROKER_PORT=443

# Path to the CA certificate PEM for verifying the broker's TLS certificate
# (required when CALENDAR_TRANSPORT=brokered).
CALENDAR_BROKER_TLS_CA=

# Path to the client certificate PEM for mutual TLS (optional).
CALENDAR_BROKER_CLIENT_CERT=

# Path to the client key PEM for mutual TLS (optional).
CALENDAR_BROKER_CLIENT_KEY=

# Agent authentication token for the broker (required when
# CALENDAR_TRANSPORT=brokered; redacted in logs/repr).
CALENDAR_BROKER_TOKEN=

# ---------------------------------------------------------------------------
# Logging / observability
# ---------------------------------------------------------------------------

# Minimum log level — one of DEBUG, INFO, WARNING, ERROR (default: INFO).
LOG_LEVEL=INFO

# Log renderer — "json" for structured production logs, "console" for
# human-friendly development output (default: console).
LOG_FORMAT=console

# Directory for date-stamped debug log files (default: .mail_log).
# An empty or whitespace-only value disables file logging.
LOG_FILE_DIR=.mail_log

# ---------------------------------------------------------------------------
# LLM provider detection (optional — only needed for `detect` subcommand)
# ---------------------------------------------------------------------------

# OpenRouter API key (required for detect).  Get one at https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-…

# LLM backend name — leave blank to use the llmio library's own tier default.
# See robotsix-llmio's README for available backends.
LLM_PROVIDER_MODEL=

# ---------------------------------------------------------------------------
# Langfuse tracing (https://langfuse.com)
# ---------------------------------------------------------------------------

# Public key from your Langfuse project settings.
# When set together with LANGFUSE_SECRET_KEY, every LLM call is traced.
LANGFUSE_PUBLIC_KEY=pk-lf-…

# Secret key from your Langfuse project settings.
LANGFUSE_SECRET_KEY=sk-lf-…

# Langfuse host (overrides the llmio library default of https://cloud.langfuse.com when set).
# Default: empty (llmio's internal default, https://cloud.langfuse.com, is used).
LANGFUSE_BASE_URL=

# ---------------------------------------------------------------------------
# Multi-account (optional — namespaced MAIL_ACCOUNTS_* scheme)
# ---------------------------------------------------------------------------
#
# By default the variables above describe a SINGLE account.  To drive several
# mailboxes from one process, use the namespaced scheme below instead: each
# account is indexed (0, 1, 2, …) and every single-account `MAIL_<X>` var
# becomes `MAIL_ACCOUNTS_<n>_<X>`.
#
# LLM_API_KEY, LLM_PROVIDER_MODEL, and LANGFUSE_* are application-wide (global) and
# read from the bare env vars above — they are NOT namespaced.
#
# Rules:
#   * Indices MUST be contiguous starting at 0 (0, 1, 2, …); a gap is an error.
#   * `MAIL_ACCOUNTS_<n>_ID` is required — a stable, filesystem/URL-safe id.
#   * `MAIL_ACCOUNTS_<n>_LABEL` is optional — a human-friendly display name.
#   * When `MAIL_ACCOUNTS_<n>_DB_PATH` is omitted it defaults to
#     `.data/<id>/mail.db` (unique per account — one DB per account).
#   * `MAIL_ACCOUNTS_DEFAULT` optionally names the default account id
#     (absent → the first index, 0).
#   * The PRESENCE of any `MAIL_ACCOUNTS_*` variable switches the loader into
#     multi-account mode; with no `MAIL_ACCOUNTS_*` vars set, the loader stays
#     single-account (full backward compatibility with the variables above).
#
# Every line in this section is intentionally COMMENTED OUT — uncomment and
# adapt.  (Active MAIL_ACCOUNTS_* lines would be flagged by the config-sync
# gate, which only knows the single-account MAIL_* fields.)
#
# MAIL_ACCOUNTS_DEFAULT=personal
#
# --- Account 0 -------------------------------------------------------------
# MAIL_ACCOUNTS_0_ID=personal
# MAIL_ACCOUNTS_0_LABEL=Personal Gmail
# MAIL_ACCOUNTS_0_IMAP_HOST=imap.gmail.com
# MAIL_ACCOUNTS_0_SMTP_HOST=smtp.gmail.com
# MAIL_ACCOUNTS_0_USERNAME=me@gmail.com
# MAIL_ACCOUNTS_0_PASSWORD=your-password-here
# MAIL_ACCOUNTS_0_DB_PATH=.data/personal/mail.db
#
# --- Account 1 -------------------------------------------------------------
# MAIL_ACCOUNTS_1_ID=work
# MAIL_ACCOUNTS_1_LABEL=Work mailbox
# MAIL_ACCOUNTS_1_IMAP_HOST=imap.work.example.com
# MAIL_ACCOUNTS_1_SMTP_HOST=smtp.work.example.com
# MAIL_ACCOUNTS_1_USERNAME=me@work.example.com
# MAIL_ACCOUNTS_1_PASSWORD=your-password-here
# MAIL_ACCOUNTS_1_DB_PATH=.data/work/mail.db
