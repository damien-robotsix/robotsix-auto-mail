{
  "$defs": {
    "MailAccount": {
      "description": "One named mailbox: a stable ``account_id`` plus its ``MailConfig``.\n\n``label`` is an optional human-friendly display name.  ``account_id`` is\na stable identifier (e.g. ``\"personal\"``) used in the account's SQLite\nfilename and, later in the epic, in URLs / board selectors \u2014 so it must\nbe non-empty and match ``^[A-Za-z0-9._-]+$``.",
      "properties": {
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "config": {
          "$ref": "#/$defs/MailConfig"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        }
      },
      "required": [
        "account_id",
        "config"
      ],
      "title": "MailAccount",
      "type": "object"
    },
    "MailConfig": {
      "description": "Immutable application settings: mail server connection parameters\nplus optional LLM credentials used by ``detect`` (and future mail\nprocessing).\n\nSensitive fields (``password``, ``llm_api_key``, ``oauth2_token``,\n``oauth2_client_secret``, ``langfuse_secret_key``) are typed as\n:class:`pydantic.SecretStr` so the JSON schema emits ``writeOnly``\nand the values are masked in ``repr`` / ``str``.",
      "properties": {
        "imap_host": {
          "title": "Imap Host",
          "type": "string"
        },
        "smtp_host": {
          "title": "Smtp Host",
          "type": "string"
        },
        "username": {
          "title": "Username",
          "type": "string"
        },
        "password": {
          "format": "password",
          "title": "Password",
          "type": "string",
          "writeOnly": true
        },
        "imap_port": {
          "default": 993,
          "title": "Imap Port",
          "type": "integer"
        },
        "imap_tls_mode": {
          "default": "direct-tls",
          "title": "Imap Tls Mode",
          "type": "string"
        },
        "smtp_port": {
          "default": 587,
          "title": "Smtp Port",
          "type": "integer"
        },
        "smtp_tls_mode": {
          "default": "starttls",
          "title": "Smtp Tls Mode",
          "type": "string"
        },
        "db_path": {
          "default": "",
          "title": "Db Path",
          "type": "string"
        },
        "imap_folder": {
          "default": "INBOX",
          "title": "Imap Folder",
          "type": "string"
        },
        "llm_api_key": {
          "default": "",
          "format": "password",
          "title": "Llm Api Key",
          "type": "string",
          "writeOnly": true
        },
        "llm_provider_model": {
          "default": "",
          "title": "Llm Provider Model",
          "type": "string"
        },
        "ingest_interval_minutes": {
          "default": 15,
          "title": "Ingest Interval Minutes",
          "type": "integer"
        },
        "archive_root": {
          "default": "robotsix-mail-archive",
          "title": "Archive Root",
          "type": "string"
        },
        "archive_enabled": {
          "default": true,
          "title": "Archive Enabled",
          "type": "boolean"
        },
        "triage_on_ingest": {
          "default": true,
          "title": "Triage On Ingest",
          "type": "boolean"
        },
        "triage_rules_path": {
          "default": "",
          "title": "Triage Rules Path",
          "type": "string"
        },
        "oauth2_token": {
          "default": "",
          "format": "password",
          "title": "Oauth2 Token",
          "type": "string",
          "writeOnly": true
        },
        "oauth2_client_id": {
          "default": "",
          "title": "Oauth2 Client Id",
          "type": "string"
        },
        "oauth2_client_secret": {
          "default": "",
          "format": "password",
          "title": "Oauth2 Client Secret",
          "type": "string",
          "writeOnly": true
        },
        "oauth2_provider": {
          "default": "",
          "title": "Oauth2 Provider",
          "type": "string"
        },
        "oauth2_tenant": {
          "default": "organizations",
          "title": "Oauth2 Tenant",
          "type": "string"
        },
        "langfuse_public_key": {
          "default": "",
          "title": "Langfuse Public Key",
          "type": "string"
        },
        "langfuse_secret_key": {
          "default": "",
          "format": "password",
          "title": "Langfuse Secret Key",
          "type": "string",
          "writeOnly": true
        },
        "langfuse_base_url": {
          "default": "",
          "title": "Langfuse Base Url",
          "type": "string"
        },
        "log_level": {
          "default": "INFO",
          "title": "Log Level",
          "type": "string"
        },
        "log_format": {
          "default": "console",
          "title": "Log Format",
          "type": "string"
        }
      },
      "required": [
        "imap_host",
        "smtp_host",
        "username",
        "password"
      ],
      "title": "MailConfig",
      "type": "object"
    }
  },
  "description": "An ordered collection of :class:`MailAccount`s plus a default id.\n\nOne SQLite DB per account\n-------------------------\nMultiple accounts are modelled as N independent :class:`MailConfig`\ninstances, each carrying its **own** ``db_path``, rather than adding an\n``account_id`` column to every table.  The rationale:\n\n- Per-account state (triage decisions, archive watermarks \u2014 all keyed\n  by ``message_id`` in each DB, plus the per-account ``triage_rules.md``\n  file) is naturally isolated with zero schema migration.\n- Each :class:`MailConfig` already owns a ``db_path`` field, so no new\n  per-row plumbing is required.\n- The cost is one SQLite file per account; uniqueness of ``db_path``\n  across accounts is therefore enforced at load time.\n\nValidation (all raise :class:`ConfigurationError`): at least one\naccount; all ``account_id``s unique; all ``MailConfig.db_path``s unique\nacross accounts; ``default_account_id`` resolves to a known account.",
  "properties": {
    "accounts": {
      "items": {
        "$ref": "#/$defs/MailAccount"
      },
      "title": "Accounts",
      "type": "array"
    },
    "default_account_id": {
      "title": "Default Account Id",
      "type": "string"
    }
  },
  "required": [
    "accounts",
    "default_account_id"
  ],
  "title": "MailAccountsConfig",
  "type": "object"
}
